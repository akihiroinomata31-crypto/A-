#include "DxLib.h"

// スコアとゲーム状態を管理するクラス
class GameManager {
public:
    int time = 99;
    int p1Score = 0, p2Score = 0;
    int phase = 1;

    void Update() {
        // 99秒のカウントダウン処理
        static int frameCounter = 0;
        if (++frameCounter >= 100) { // 1秒経過
            if (time > 0) time--;
            frameCounter = 0;
        }

        // フェーズ管理
        if (time > 54) phase = 1;
        else if (time > 24) phase = 2; // ボス出現
        else phase = 3;
    }

    void DrawUI() {
        // タイマー描画
        DrawFormatString(350, 20, GetColor(255, 255, 0), "TIME: %d", time);
        // スコア描画
        DrawFormatString(50, 50, GetColor(255, 255, 255), "P1 Score: %d", p1Score);
        DrawFormatString(500, 50, GetColor(255, 255, 255), "P2 Score: %d", p2Score);
        // フェーズ情報
        DrawFormatString(350, 60, GetColor(0, 255, 0), "Phase: %d", phase);
    }
};

int WINAPI WinMain(HINSTANCE, HINSTANCE, LPSTR, int) {
    ChangeWindowMode(TRUE);
    SetGraphMode(1280, 720, 32);
    if (DxLib_Init() == -1) return -1;
    SetDrawScreen(DX_SCREEN_BACK);

    GameManager game;

    while (ProcessMessage() == 0 && CheckHitKey(KEY_INPUT_ESCAPE) == 0) {
        ClearDrawScreen();

        game.Update();
        game.DrawUI();

        ScreenFlip();
    }

    DxLib_End();
    return 0;
}
